{
  "manifest_version": 3,
  "name": "VoiceMarkets",
  "version": "0.1.0",
  "description": "音声でブックマーク・履歴を検索して開く Chrome 拡張機能",
  "permissions": ["bookmarks", "history", "tabs"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "VoiceMarkets",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  }
}
